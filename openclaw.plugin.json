{
  "id": "openclaw-channel-nextcompany",
  "name": "NextCompany Channel",
  "description": "Connect to NextCompany as an AI agent via WebSocket",
  "version": "0.1.1",
  "channels": [
    "nextcompany"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Agent display name in NextCompany"
      },
      "imageAttachments": {
        "type": "object",
        "additionalProperties": false,
        "description": "Inline image download and base64 attachment delivery for agent comments/messages",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Download same-origin inline images and deliver them as OpenClaw attachments"
          },
          "allowExternalImages": {
            "type": "boolean",
            "default": false,
            "description": "Allow external image URLs. External hosts must also be listed in allowedExternalHosts."
          },
          "allowedExternalHosts": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "allowedMimeTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["image/png", "image/jpeg", "image/webp", "image/gif"]
            },
            "default": ["image/png", "image/jpeg", "image/webp", "image/gif"]
          },
          "maxImages": { "type": "integer", "minimum": 1, "default": 5 },
          "maxBytesPerImage": { "type": "integer", "minimum": 1, "default": 8388608 },
          "maxAggregateBytes": { "type": "integer", "minimum": 1, "default": 20971520 },
          "timeoutMs": { "type": "integer", "minimum": 1, "default": 10000 },
          "aggregateTimeoutMs": { "type": "integer", "minimum": 1, "default": 20000 },
          "maxRedirects": { "type": "integer", "minimum": 0, "default": 2 }
        }
      }
    }
  },
  "channelConfigs": {
    "nextcompany": {
      "label": "NextCompany",
      "description": "Connect to NextCompany as an AI agent via WebSocket",
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "configWrites": {
            "type": "boolean"
          },
          "name": {
            "type": "string",
            "description": "Default agent display name"
          },
          "apiKey": {
            "type": "string",
            "description": "Legacy single-account NextCompany API key"
          },
          "url": {
            "type": "string",
            "description": "Legacy single-account NextCompany WebSocket URL"
          },
          "projectId": {
            "type": "string",
            "description": "Optional default NextCompany project id"
          },
          "accounts": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "apiKey": {
                  "type": "string",
                  "description": "NextCompany API key"
                },
                "url": {
                  "type": "string",
                  "description": "NextCompany agent WebSocket URL"
                },
                "name": {
                  "type": "string",
                  "description": "Agent display name"
                },
                "projectId": {
                  "type": "string",
                  "description": "Optional default NextCompany project id"
                }
              }
            }
          }
        }
      }
    }
  }
}
